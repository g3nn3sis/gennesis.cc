{
  "rewrites": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "store.gennesis.cc"
        }
      ],
      "destination": "/store"
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "store.gennesis.cc"
        }
      ],
      "destination": "/store/$1"
    }
  ]
}
